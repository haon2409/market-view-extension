{
  "manifest_version": 3,
  "name": "VN-Index Scraper",
  "version": "1.0",
  "description": "Cào dữ liệu VN-Index từ Investing.com",
  "permissions": ["storage"],
  "host_permissions": ["https://www.investing.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon64.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.investing.com/indices/vn*"],
      "js": ["content.js"]
    }
  ]
}
